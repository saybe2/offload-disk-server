{
  "id": null,
  "uid": "offload-overview",
  "title": "Offload Overview",
  "tags": ["offload", "storage"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Upload Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "offload_upload_rate_bytes_per_second" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Mirror Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "offload_mirror_rate_bytes_per_second" }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Download Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "offload_download_rate_bytes_per_second" }],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Mirror Concurrency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "offload_mirror_sync_concurrency" }],
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Mirror Paused",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "offload_mirror_sync_paused" }],
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No" }, "1": { "text": "Yes" } } }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "offload_upload_rate_bytes_per_second", "legendFormat": "upload" },
        { "refId": "B", "expr": "offload_mirror_rate_bytes_per_second", "legendFormat": "mirror" },
        { "refId": "C", "expr": "offload_download_rate_bytes_per_second", "legendFormat": "download" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "Bps", "decimals": 2 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Mirror Health",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "offload_mirror_parts_done_total", "legendFormat": "parts done total" },
        { "refId": "B", "expr": "offload_mirror_parts_error_total", "legendFormat": "parts error total" },
        { "refId": "C", "expr": "offload_mirror_rate_limited_total", "legendFormat": "429 total" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Mirror Provider Done",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "offload_mirror_provider_done_total{provider=\"discord\"}", "legendFormat": "discord done" },
        { "refId": "B", "expr": "offload_mirror_provider_done_total{provider=\"telegram\"}", "legendFormat": "telegram done" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Mirror Provider Errors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "offload_mirror_provider_error_total{provider=\"discord\"}", "legendFormat": "discord errors" },
        { "refId": "B", "expr": "offload_mirror_provider_error_total{provider=\"telegram\"}", "legendFormat": "telegram errors" },
        { "refId": "C", "expr": "offload_mirror_provider_rate_limited_total{provider=\"discord\"}", "legendFormat": "discord 429" },
        { "refId": "D", "expr": "offload_mirror_provider_rate_limited_total{provider=\"telegram\"}", "legendFormat": "telegram 429" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Node CPU / Memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(offload_node_process_cpu_user_seconds_total[1m]) + rate(offload_node_process_cpu_system_seconds_total[1m])",
          "legendFormat": "cpu cores"
        },
        {
          "refId": "B",
          "expr": "offload_node_process_resident_memory_bytes",
          "legendFormat": "rss memory"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 2 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rss memory" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Upload Avg Archive Time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "offload_upload_archive_avg_ms" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Mirror Avg Part Time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "offload_mirror_part_avg_ms" }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Upload Errors Total",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "offload_upload_archives_error_total" }],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Download Errors Total",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "offload_download_error_total" }],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none" }
    }
  ]
}

